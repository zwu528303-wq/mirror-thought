ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=
ANTHROPIC_VERSION=2023-06-01
ANTHROPIC_MAX_TOKENS=1200

# Optional. Use this only when Anthropic docs require a beta header for a feature you enable.
ANTHROPIC_BETA_HEADERS=

# Optional. Defaults to https://api.anthropic.com/v1/messages.
ANTHROPIC_MESSAGES_URL=

# Optional. Set to mock when you want the old local deterministic responses.
# VITE_JINGGUAN_API_MODE=mock
