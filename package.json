{
  "name": "jingguan-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:mock": "VITE_JINGGUAN_API_MODE=mock vite",
    "build": "tsc --noEmit && npm run typecheck:node && vite build",
    "eval:jingguan": "node scripts/eval-jingguan-output.mjs",
    "smoke:api": "node scripts/smoke-api.mjs",
    "smoke:api:chat": "node scripts/smoke-api.mjs --chat",
    "typecheck:node": "tsc -p tsconfig.node.json --noEmit",
    "preview": "vite preview"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vite": "^6.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "typescript": "^5.7.2"
  }
}
